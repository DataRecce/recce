        "raw_code": "with payments as (\n    select * from {{ ref('stg_payments') }}\n),\n\norders as (\n    select * from {{ ref('orders') }}\n),\n\nfinal as (\n    select\n        p.payment_id,\n        p.order_id,\n        o.customer_id,\n        o.order_date,\n        p.payment_method,\n        p.amount,\n        o.status as order_status\n    from payments p\n    left join orders o on p.order_id = o.order_id\n)\n\nselect * from final",
