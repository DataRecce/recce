#!/bin/bash
set -e

REPO_ROOT=$(git rev-parse --show-toplevel)
export GIT_WORK_TREE="$REPO_ROOT"

# Reminder: All commits require --signoff (-s) for DCO compliance
# The commit-msg hook will enforce this, but here's a heads up!

# Check if there are any staged TypeScript/JavaScript files in the js directory
STAGED_JS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep "^js/" | grep -E '\.(ts|tsx|js|jsx|mjs)$' || true)

if [ -n "$STAGED_JS_FILES" ]; then
	echo "TypeScript/JavaScript files changed, running lint..."
	(cd "$REPO_ROOT/js" && pnpm lint:staged)
else
	echo "No TypeScript/JavaScript files changed, skipping lint."
fi

# start templated
INSTALL_PYTHON=${INSTALL_PYTHON:-$(command -v python || true)}
ARGS="hook-impl --config=.pre-commit-config.yaml --hook-type=pre-commit"
# end templated

HERE="$(cd "$(dirname "$0")" && pwd)"
STRIP_JS_HUSKY=$(echo "$HERE" | sed 's|/js/\.husky$||')
ARGS="$ARGS --hook-dir $STRIP_JS_HUSKY -- $*"

if [ -x "$INSTALL_PYTHON" ] && "$INSTALL_PYTHON" -c "import pre_commit" 2>/dev/null; then
	exec "$INSTALL_PYTHON" -mpre_commit $ARGS
elif command -v pre-commit >/dev/null; then
	exec pre-commit $ARGS
else
	echo '`pre-commit` not found.  Did you forget to activate your virtualenv?' 1>&2
	echo "Skipping pre-commit hook."
fi
