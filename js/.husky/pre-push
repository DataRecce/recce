#!/bin/bash
set -e

# Determine which commits are being pushed by comparing local ref to remote ref.
# This reads the standard pre-push stdin format: <local ref> <local sha> <remote ref> <remote sha>
MERGE_BASE=""
while read -r LOCAL_REF LOCAL_SHA REMOTE_REF REMOTE_SHA; do
	if [ "$LOCAL_SHA" = "0000000000000000000000000000000000000000" ]; then
		# Deleting a branch, nothing to check
		continue
	fi
	if [ "$REMOTE_SHA" = "0000000000000000000000000000000000000000" ]; then
		# New branch — compare against main
		MERGE_BASE=$(git merge-base HEAD main 2>/dev/null || echo "")
	else
		MERGE_BASE="$REMOTE_SHA"
	fi
done

if [ -z "$MERGE_BASE" ]; then
	echo "No commits to push, skipping pre-push checks."
	exit 0
fi

# Check if any TypeScript/JavaScript source files were changed in the commits being pushed
PUSHED_JS_FILES=$(git diff --name-only --diff-filter=ACM "$MERGE_BASE"..HEAD | grep -E "^js/.*\.(ts|tsx|js|jsx)$" || true)

if [ -n "$PUSHED_JS_FILES" ]; then
	RELATIVE_FILES=$(echo "$PUSHED_JS_FILES" | sed 's|^js/||')

	echo "TypeScript/JavaScript source files changed, running type check..."
	cd js
	pnpm type:check
	cd ..

	echo "Running tests related to changed files..."
	cd js
	echo "$RELATIVE_FILES" | xargs pnpm exec vitest related --run
	cd ..
else
	echo "No TypeScript/JavaScript source files changed, skipping type check and tests."
fi
