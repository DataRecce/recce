{
  "name": "recce",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=24.11"
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build && cp -R out/. ../recce/data/ && rm -rf out",
    "start": "next start",
    "lint": "biome check --diagnostic-level=error",
    "lint:fix": "biome check --write --diagnostic-level=error",
    "lint:staged": "biome check --staged --diagnostic-level=error",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "type:check": "tsc --noEmit",
    "clean": "rimraf ../recce/data",
    "prepare": "cd .. && husky js/.husky"
  },
